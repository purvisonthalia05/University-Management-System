import java.util.*;

class InvalidMarksException extends Exception {
    InvalidMarksException(String msg) {
        super(msg);
    }
}

abstract class Person {
    protected int id;
    protected String name;

    Person(int id, String name) {
        this.id = id;
        this.name = name;
    }

    abstract void display();

    public int getId() {
        return id;
    }
}

class Student extends Person {

    private int age;
    private String department;
    private double marks;
    private double gpa;

    Student(int id, String name,
            int age,
            String department,
            double marks) {

        super(id, name);

        this.age = age;
        this.department = department;
        this.marks = marks;

        calculateGPA();
    }

    private void calculateGPA() {
        gpa = (marks / 100.0) * 4.0;
    }

    public double getMarks() {
        return marks;
    }

    public double getGPA() {
        return gpa;
    }

    public String getDepartment() {
        return department;
    }

    @Override
    void display() {

        System.out.println("----------------------------");
        System.out.println("Student ID : " + id);
        System.out.println("Name       : " + name);
        System.out.println("Age        : " + age);
        System.out.println("Department : " + department);
        System.out.println("Marks      : " + marks);
        System.out.printf("GPA        : %.2f\n", gpa);
    }
}

class Professor extends Person {

    private String subject;
    private int experience;

    Professor(int id,
              String name,
              String subject,
              int experience) {

        super(id, name);

        this.subject = subject;
        this.experience = experience;
    }

    public int getExperience() {
        return experience;
    }

    @Override
    void display() {

        System.out.println("----------------------------");
        System.out.println("Professor ID : " + id);
        System.out.println("Name         : " + name);
        System.out.println("Subject      : " + subject);
        System.out.println("Experience   : "
                + experience + " years");
    }
}

public class UniversityManagementSystem {

    static Scanner sc = new Scanner(System.in);

    static ArrayList<Student> students =
            new ArrayList<>();

    static ArrayList<Professor> professors =
            new ArrayList<>();

    // RECURSIVE SEARCH

    static Student searchStudent(
            int index,
            int id) {

        if (index == students.size())
            return null;

        if (students.get(index)
                .getId() == id)
            return students.get(index);

        return searchStudent(
                index + 1,
                id);
    }

    static void addStudent() {

        try {

            System.out.print("Student ID : ");
            int id = sc.nextInt();
            sc.nextLine();

            System.out.print("Name : ");
            String name = sc.nextLine();

            System.out.print("Age : ");
            int age = sc.nextInt();
            sc.nextLine();

            System.out.print("Department : ");
            String dept = sc.nextLine();

            System.out.print("Marks : ");
            double marks = sc.nextDouble();

            if (marks < 0 || marks > 100)
                throw new InvalidMarksException(
                        "Marks must be between 0 and 100");

            students.add(
                    new Student(
                            id,
                            name,
                            age,
                            dept,
                            marks));

            System.out.println(
                    "Student Added Successfully!");

        }

        catch (InvalidMarksException e) {

            System.out.println(
                    e.getMessage());

        }

        catch (Exception e) {

            System.out.println(
                    "Invalid Input!");

            sc.nextLine();
        }
    }

    static void addProfessor() {

        try {

            System.out.print("Professor ID : ");
            int id = sc.nextInt();
            sc.nextLine();

            System.out.print("Name : ");
            String name = sc.nextLine();

            System.out.print("Subject : ");
            String subject = sc.nextLine();

            System.out.print("Experience : ");
            int exp = sc.nextInt();

            professors.add(
                    new Professor(
                            id,
                            name,
                            subject,
                            exp));

            System.out.println(
                    "Professor Added Successfully!");

        }

        catch (Exception e) {

            System.out.println(
                    "Invalid Input!");

            sc.nextLine();
        }
    }

    static void displayStudents() {

        if (students.isEmpty()) {

            System.out.println(
                    "No Students Found!");

            return;
        }

        for (Student s : students)
            s.display();
    }

    static void displayProfessors() {

        if (professors.isEmpty()) {

            System.out.println(
                    "No Professors Found!");

            return;
        }

        for (Professor p : professors)
            p.display();
    }

    static void searchStudentMenu() {

        System.out.print(
                "Enter Student ID : ");

        int id = sc.nextInt();

        Student s =
                searchStudent(0, id);

        if (s == null)
            System.out.println(
                    "Student Not Found!");

        else
            s.display();
    }

    static void sortStudentsByGPA() {

        Collections.sort(
                students,
                (s1, s2) ->
                        Double.compare(
                                s2.getGPA(),
                                s1.getGPA()));

        System.out.println(
                "Students Sorted By GPA");
    }

    static void sortProfessors() {

        Collections.sort(
                professors,
                (p1, p2) ->
                        p2.getExperience()
                                - p1.getExperience());

        System.out.println(
                "Professors Sorted By Experience");
    }

    static void reports() {

        System.out.println(
                "\n===== UNIVERSITY REPORT =====");

        System.out.println(
                "Total Students : "
                        + students.size());

        System.out.println(
                "Total Professors : "
                        + professors.size());

        if (!students.isEmpty()) {

            Student topper =
                    Collections.max(
                            students,
                            Comparator.comparingDouble(
                                    Student::getGPA));

            System.out.println(
                    "Top Performer : "
                            + topper.name);

            System.out.printf(
                    "Highest GPA : %.2f\n",
                    topper.getGPA());

            double total = 0;

            for (Student s : students)
                total += s.getGPA();

            System.out.printf(
                    "Average GPA : %.2f\n",
                    total / students.size());
        }
    }

    public static void main(String[] args) {

        int choice;

        do {

            System.out.println(
                    "\n========= UNIVERSITY MANAGEMENT =========");

            System.out.println(
                    "1. Add Student");

            System.out.println(
                    "2. Add Professor");

            System.out.println(
                    "3. Display Students");

            System.out.println(
                    "4. Display Professors");

            System.out.println(
                    "5. Search Student");

            System.out.println(
                    "6. Sort Students By GPA");

            System.out.println(
                    "7. Sort Professors By Experience");

            System.out.println(
                    "8. Reports");

            System.out.println(
                    "9. Exit");

            System.out.print(
                    "Enter Choice : ");

            choice = sc.nextInt();

            switch (choice) {

                case 1:
                    addStudent();
                    break;

                case 2:
                    addProfessor();
                    break;

                case 3:
                    displayStudents();
                    break;

                case 4:
                    displayProfessors();
                    break;

                case 5:
                    searchStudentMenu();
                    break;

                case 6:
                    sortStudentsByGPA();
                    break;

                case 7:
                    sortProfessors();
                    break;

                case 8:
                    reports();
                    break;

                case 9:
                    System.out.println(
                            "Thank You!");
                    break;

                default:
                    System.out.println(
                            "Invalid Choice!");
            }

        } while (choice != 9);
    }
}
